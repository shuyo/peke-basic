	movea.l	data(pc),a0
	move.w	(a0),BG1_scroll_reg
	addq.l	#4,a0
	move.l	a0,data
	lea.l	ras(pc),a0
	subq.w	#1,(a0)
	bcs	_hsync_owari
	movea.l	(sp)+,a0
@@:
	rte


