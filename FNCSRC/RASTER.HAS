 * BG0 横
__hsync0:
	subq.w	#1,ras1
	bcc	@f
	move.l	#_hsync0,H_SYNC_ADR.w
_hsync0:
	move.l	a0,-(sp)
	movea.l	data(pc),a0
	move.w	(a0),BG0_scroll_reg
	addq.l	#4,a0
	move.l	a0,data
	lea.l	ras(pc),a0
	subq.w	#1,(a0)
	bcs	_hsync_owari
	movea.l	(sp)+,a0
@@:
	rte


 * BG1 横
__hsync1:
	subq.w	#1,ras1
	bcc	@f
	move.l	#_hsync1,H_SYNC_ADR.w
