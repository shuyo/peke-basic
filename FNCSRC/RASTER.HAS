 * BG0 縦横 差分
__hsync6:
	subq.w	#1,ras1
	bcc	@f
	move.l	#_hsync6,H_SYNC_ADR.w
_hsync6:
	movem.l	d0/a0,-(sp)
	movea.l	data(pc),a0
	move.l	(a0)+,d0
	add.l	d0,BG0_scroll_reg		* ここがポイント
	move.l	(sp)+,d0
	move.l	a0,data
	lea.l	ras(pc),a0
	subq.w	#1,(a0)
	bcs	_hsync_owari
	movea.l	(sp)+,a0
@@:
	rte


